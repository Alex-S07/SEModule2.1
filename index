const bold = (text) => text.split(/(\*\*[^*]+\*\*)/g).map((p, i) =>
  p.startsWith("**") && p.endsWith("**")
    ? <strong key={i} style={{ color: "#fbbf24" }}>{p.slice(2, -2)}</strong>
    : <span key={i}>{p}</span>
);

function Flashcards() {
  const [flipped, setFlipped] = useState({});
  const [done, setDone] = useState({});
  return (
    <div>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-end", marginBottom: "1.2rem" }}>
        <div>
          <h2 style={{ fontFamily: "Georgia, serif", fontSize: "1.4rem", color: "#f1f5f9" }}>⚡ Flashcards</h2>
          <p style={{ color: "#475569", fontSize: "0.8rem", marginTop: "3px" }}>Tap to reveal · Mark done to track progress</p>
        </div>
        <span style={{ color: "#4ade80", fontSize: "0.82rem", fontWeight: 700 }}>
          {Object.values(done).filter(Boolean).length}/{flashcards.length} done
        </span>
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(255px,1fr))", gap: "0.8rem" }}>
        {flashcards.map((c, i) => (
          <div key={i} style={{
            background: done[i] ? "#051a10" : flipped[i] ? "#0d1e35" : "#0f172a",
            border: `1px solid ${done[i] ? "#166534" : flipped[i] ? "#3b82f6" : "#1e293b"}`,
            borderRadius: "12px", padding: "1rem", cursor: "pointer",
            transition: "all 0.25s", minHeight: "82px",
            display: "flex", flexDirection: "column", justifyContent: "space-between", gap: "0.6rem",
          }}
            onClick={() => setFlipped(f => ({ ...f, [i]: !f[i] }))}
          >
            <p style={{ margin: 0, fontSize: "0.84rem", lineHeight: 1.55, color: flipped[i] ? "#7dd3fc" : "#e2e8f0", fontWeight: flipped[i] ? 400 : 600 }}>
              {flipped[i] ? `✅ ${c.a}` : `❓ ${c.q}`}
            </p>
            {flipped[i] && (
              <button onClick={e => { e.stopPropagation(); setDone(d => ({ ...d, [i]: !d[i] })); }} style={{
                alignSelf: "flex-end", background: done[i] ? "#14532d" : "#1e293b",
                border: `1px solid ${done[i] ? "#4ade80" : "#334155"}`,
                color: done[i] ? "#4ade80" : "#64748b", fontSize: "0.72rem",
                padding: "2px 8px", borderRadius: "6px", cursor: "pointer",
              }}>
                {done[i] ? "✓ Done" : "Mark done"}
              </button>
            )}
          </div>
        ))}
      </div>
    </div>
  );
}

